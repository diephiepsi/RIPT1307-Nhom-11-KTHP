generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  STUDENT
  LECTURER
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  fullName  String
  password  String
  role      Role     @default(STUDENT)
  locked    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions Question[]
  comments  Comment[]
  votes     Vote[]
}

model Tag {
  id   String @id @default(cuid())
  name String @unique

  questions QuestionTag[]
}

model Question {
  id        String    @id @default(cuid())
  title     String
  content   String    @db.LongText
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  tags     QuestionTag[]
  comments Comment[]
  votes    Vote[]

  @@index([createdAt])
}

model QuestionTag {
  questionId String
  tagId      String
  question   Question @relation(fields: [questionId], references: [id])
  tag        Tag      @relation(fields: [tagId], references: [id])

  @@id([questionId, tagId])
}

model Comment {
  id        String    @id @default(cuid())
  content   String    @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  questionId String
  question   Question @relation(fields: [questionId], references: [id])

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  votes Vote[]
}

model Vote {
  id        String   @id @default(cuid())
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  questionId String?
  question   Question? @relation(fields: [questionId], references: [id])

  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id])

  @@unique([userId, questionId])
  @@unique([userId, commentId])
  @@index([questionId])
  @@index([commentId])
}
